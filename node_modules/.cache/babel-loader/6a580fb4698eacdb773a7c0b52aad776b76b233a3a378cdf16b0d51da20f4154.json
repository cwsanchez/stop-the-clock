{"ast":null,"code":"import{create}from'zustand';const useTimerStore=create(set=>({elapsedMs:0,running:false,phase:'idle',// 'idle' | 'running' | 'stopped-success' | 'stopped-fail'\nsetElapsedMs:ms=>set({elapsedMs:ms}),setRunning:running=>set({running}),setPhase:phase=>set({phase}),startTimer:()=>set({running:true,phase:'running'}),stopTimer:wasSuccess=>set({running:false,phase:wasSuccess?'stopped-success':'stopped-fail'}),resetTimer:()=>set({elapsedMs:0,running:false,phase:'idle'})}));export default useTimerStore;","map":{"version":3,"names":["create","useTimerStore","set","elapsedMs","running","phase","setElapsedMs","ms","setRunning","setPhase","startTimer","stopTimer","wasSuccess","resetTimer"],"sources":["/workspace/src/stores/useTimerStore.js"],"sourcesContent":["import { create } from 'zustand';\n\nconst useTimerStore = create((set) => ({\n  elapsedMs: 0,\n  running: false,\n  phase: 'idle', // 'idle' | 'running' | 'stopped-success' | 'stopped-fail'\n\n  setElapsedMs: (ms) => set({ elapsedMs: ms }),\n  setRunning: (running) => set({ running }),\n  setPhase: (phase) => set({ phase }),\n\n  startTimer: () => set({ running: true, phase: 'running' }),\n\n  stopTimer: (wasSuccess) =>\n    set({\n      running: false,\n      phase: wasSuccess ? 'stopped-success' : 'stopped-fail',\n    }),\n\n  resetTimer: () =>\n    set({ elapsedMs: 0, running: false, phase: 'idle' }),\n}));\n\nexport default useTimerStore;\n"],"mappings":"AAAA,OAASA,MAAM,KAAQ,SAAS,CAEhC,KAAM,CAAAC,aAAa,CAAGD,MAAM,CAAEE,GAAG,GAAM,CACrCC,SAAS,CAAE,CAAC,CACZC,OAAO,CAAE,KAAK,CACdC,KAAK,CAAE,MAAM,CAAE;AAEfC,YAAY,CAAGC,EAAE,EAAKL,GAAG,CAAC,CAAEC,SAAS,CAAEI,EAAG,CAAC,CAAC,CAC5CC,UAAU,CAAGJ,OAAO,EAAKF,GAAG,CAAC,CAAEE,OAAQ,CAAC,CAAC,CACzCK,QAAQ,CAAGJ,KAAK,EAAKH,GAAG,CAAC,CAAEG,KAAM,CAAC,CAAC,CAEnCK,UAAU,CAAEA,CAAA,GAAMR,GAAG,CAAC,CAAEE,OAAO,CAAE,IAAI,CAAEC,KAAK,CAAE,SAAU,CAAC,CAAC,CAE1DM,SAAS,CAAGC,UAAU,EACpBV,GAAG,CAAC,CACFE,OAAO,CAAE,KAAK,CACdC,KAAK,CAAEO,UAAU,CAAG,iBAAiB,CAAG,cAC1C,CAAC,CAAC,CAEJC,UAAU,CA